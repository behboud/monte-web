{
  "name": "monte-theme",
  "version": "1.0.0",
  "description": "Custom WordPress theme for Montessorischule Gilching",
  "scripts": {
    "watch": "npm-run-all --parallel watch:*",
    "watch:css": "tailwindcss -i ./assets/css/main.css -o ./dist/css/main.css --watch",
    "watch:js": "NODE_ENV=development webpack --watch",
    "build": "npm-run-all build:*",
    "build:css": "tailwindcss -i ./assets/css/main.css -o ./dist/css/main.css --minify",
    "build:js": "NODE_ENV=production webpack"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "css-loader": "^6.8.1",
    "mini-css-extract-plugin": "^2.7.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.32",
    "postcss-import": "^16.1.1",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.4.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "franken-ui": "2.0.0",
    "mmenu-js": "^9.3.0",
    "swiper": "^11.0.5"
  }
}
