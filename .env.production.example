# Monte-Web WordPress Production Environment Configuration
# IMPORTANT: Copy this to .env.production and update all passwords before deploying

# Database Configuration
WORDPRESS_DB_HOST=db
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
WORDPRESS_DB_NAME=wordpress_db
WORDPRESS_TABLE_PREFIX=wp_monte_

# MySQL Root Configuration
MYSQL_ROOT_PASSWORD=CHANGE_THIS_TO_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=wordpress_db
MYSQL_USER=wordpress
MYSQL_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# WordPress Site URLs (Update to production domain)
WP_HOME=https://your-production-domain.com
WP_SITEURL=https://your-production-domain.com

# WordPress Security Keys
# Generate new keys at: https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
SECURE_AUTH_KEY='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
LOGGED_IN_KEY='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
NONCE_KEY='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
AUTH_SALT='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
SECURE_AUTH_SALT='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
LOGGED_IN_SALT='GENERATE_NEW_KEY_FROM_WORDPRESS_API'
NONCE_SALT='GENERATE_NEW_KEY_FROM_WORDPRESS_API'

# Production Settings
WP_DEBUG=false
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false
WP_ENVIRONMENT_TYPE=production

# SSL Configuration
FORCE_SSL_ADMIN=true

# Security Settings
DISALLOW_FILE_EDIT=true
AUTOMATIC_UPDATER_DISABLED=true
WP_AUTO_UPDATE_CORE=false

# Performance Settings
WP_CACHE=true
COMPRESS_CSS=true
COMPRESS_SCRIPTS=true
